{
  "version": 1,
  "hooks": {
    "preSendMessage": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/prompt-word-filter.sh",
        "powershell": ".github/hooks/scripts/prompt-word-filter.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/session-logger.sh",
        "powershell": ".github/hooks/scripts/session-logger.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/pre-tool-guard.sh",
        "powershell": ".github/hooks/scripts/pre-tool-guard.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/audit-logger.sh",
        "powershell": ".github/hooks/scripts/audit-logger.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/session-logger.sh",
        "powershell": ".github/hooks/scripts/session-logger.ps1",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
